{
  "manifest_version": 2,
  "name": "Sound Booster 1000%",
  "version": "1.0",
  "description": "Boost your browser's audio volume up to 1000% with a sleek interface. Ideal for quiet videos and media.",
  "permissions": [
    "storage",
    "tabs",
    "<all_urls>"
  ],
  "icons": {
    "256": "icon.png"
  },
  "browser_action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html",
    "default_title": "Sound Booster"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content_script.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "sound-booster-1000@mert-gulcan",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}